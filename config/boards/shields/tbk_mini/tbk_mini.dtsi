/*
 * TBK Mini shared devicetree include
 *
 * Layout: 3×6 + 3 thumb keys per side = 42 keys total
 *
 *   Left half:  6 cols × 3 rows  +  3 thumb keys  (row 3, cols 3-5)
 *   Right half: 6 cols × 3 rows  +  3 thumb keys  (row 3, cols 6-8)
 *
 * Matrix wiring (col2row, diodes from column to row):
 *   Rows  R0..R3  (4 rows: 3 main + 1 thumb row)
 *   Cols  C0..C5  (6 columns per side)
 *
 * Pro Micro pin mapping (adjust to your actual wiring):
 *   Rows:  pin 4 (R0), pin 5 (R1), pin 6 (R2), pin 7 (R3)
 *   Cols:  pin 8 (C0), pin 9 (C1), pin 10 (C2), pin 11 (C3), pin 14 (C4), pin 15 (C5)
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    /*
     * Combined matrix transform (left cols 0-5, right cols 6-11).
     *
     * Physical layout:
     *
     *  L00 L01 L02 L03 L04 L05 | R00 R01 R02 R03 R04 R05
     *  L10 L11 L12 L13 L14 L15 | R10 R11 R12 R13 R14 R15
     *  L20 L21 L22 L23 L24 L25 | R20 R21 R22 R23 R24 R25
     *              L31 L32 L33 | R31 R32 R33
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        map = <
        // ╭──────────────────────────────────────────╮ ╭──────────────────────────────────────────╮
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)   RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)   RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)   RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
                                    RC(3,3) RC(3,4) RC(3,5)   RC(3,6) RC(3,7) RC(3,8)
        // ╰──────────────────────────────────────────╯ ╰──────────────────────────────────────────╯
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pro_micro 4  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R0 */
            , <&pro_micro 5  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R1 */
            , <&pro_micro 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R2 */
            , <&pro_micro 7  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* R3 – thumb row */
            ;
        /* col-gpios are defined per-side in the left/right overlay files */
    };

    physical_layout_0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        kscan = <&kscan0>;
        transform = <&default_transform>;
    };

    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout_0;
    };
};
